
# CORS_ORIGINS=http://localhost:3000
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Primera petición a PokéAPI al arrancar (omitida con NODE_ENV=test o POKEAPI_WARMUP=false).
POKEAPI_WARMUP=true

# Caché en memoria del detalle por id/nombre; 0 desactiva. MAX evicción FIFO al superar el tope.
POKEAPI_DETAIL_CACHE_TTL_MS=300000
POKEAPI_DETAIL_CACHE_MAX=500

# Servicio db; el backend usa los mismos valores como DB_USER, DB_PASSWORD, DB_NAME
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pokemon

# Servicios backend y frontend y puertos
BACKEND_PORT=4000
FRONTEND_PORT=3000
DB_PORT=5432
LOKI_PORT=3100
GRAFANA_PORT=3010
PGADMIN_PORT=5050

# Logs y sincronización de la base de datos
STRUCTURED_LOGS=true
TYPEORM_SYNC=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Build del servicio frontend (Vite: URL pública del API en el navegador)
VITE_API_URL=http://localhost:4000

# Perfil compose --profile full: Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Perfil compose --profile full: pgAdmin (UI web, no credenciales de PostgreSQL)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# El SPA genera y envía X-Client-Id (localStorage) en REST y auth de Socket.IO; no requiere variables extra.
